{
  "name": "@answerlay/embed",
  "version": "0.3.0",
  "description": "Embeddable Lit web component chat widget for Answerlay — runs in-browser LLMs (Qwen3, SmolLM2) on desktop, scenario matching on mobile.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./embed": {
      "import": "./dist/embed.js"
    },
    "./types": {
      "types": "./dist/types/public/types.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "./dist/embed.js"
  ],
  "scripts": {
    "dev": "vite",
    "clean": "rm -rf dist",
    "build:embed": "vite build",
    "build:lib": "vite build --mode lib",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run clean && npm run build:embed && npm run build:lib && npm run build:types",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,html,css,md}\" \"tests/**/*.ts\"",
    "size": "size-limit",
    "release": "echo 'Releases are created automatically by CI on push to main'"
  },
  "keywords": [
    "answerlay",
    "chat",
    "embed",
    "widget",
    "lit",
    "web-component",
    "rag",
    "webgpu",
    "llm",
    "qwen",
    "smollm",
    "wllama"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pavelsima/Answerlay-embed.git"
  },
  "homepage": "https://github.com/pavelsima/Answerlay-embed#readme",
  "bugs": {
    "url": "https://github.com/pavelsima/Answerlay-embed/issues"
  },
"dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@wllama/wllama": "^2.4.0",
    "franc-min": "^6.2.0",
    "fuse.js": "^7.0.0",
    "lit": "^3.2.0",
    "marked": "^14.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.39.4",
    "@open-wc/testing-helpers": "^3.0.0",
    "@size-limit/preset-small-lib": "^11.1.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/browser": "^2.1.0",
    "eslint": "^9.0.0",
    "globals": "^15.15.0",
    "playwright": "^1.48.0",
    "prettier": "^3.3.0",
    "size-limit": "^11.1.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
